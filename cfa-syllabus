priv_p:{title:'L3 Pathway: Private Markets',eye:'Level 3 Specialised Pathway &#183; 30&#8211;35% of exam',weights:{l1:'&#8212;',l2:'&#8212;',l3:'30&#8211;35%'},
  overview:'For PE analysts, private credit investors, infrastructure fund managers, and real asset specialists. Deal structuring, valuation, performance metrics, and portfolio management for illiquid alternative investments.',
  notes:[
    {title:'Private Equity',lv:['l3'],sum:'Venture capital, LBOs, fund structure and economics, and performance measurement.',
      kcs:[
        {title:'LBO Analysis & Value Creation',lv:['l3'],col:'#E67E22',lead:'Acquire mature company using debt. Three levers: leverage, operational improvement, multiple expansion.',
          notes:[{t:'LBO Logic',b:'Model FCF &#8594; debt repayment schedule &#8594; exit enterprise value (EBITDA &#215; exit multiple) &#8594; subtract debt &#8594; equity proceeds &#8594; calculate IRR. Sensitivity to: entry multiple, exit multiple, EBITDA growth, leverage ratio, hold period.'},{t:'Value Creation Levers',b:'1. Financial engineering: leverage amplifies equity returns. 2. Operational: EBITDA growth via cost cuts and revenue growth. 3. Multiple expansion: buy at 7&#215; EBITDA, sell at 10&#215; EBITDA. Hold period: 4&#8211;6 years. Target IRR: 20%+.'}]},
        {title:'PE Performance Metrics',lv:['l3'],col:'#2980B9',lead:'IRR, MOIC/TVPI, DPI, RVPI. J-curve effect. Net IRR matters for LPs.',
          notes:[{t:'Metrics',b:'IRR: annualised rate, accounts for timing. MOIC/TVPI: total value / paid-in = simple wealth multiple. DPI: distributed / paid-in = realised only. RVPI: residual value / paid-in = unrealised (subject to marking bias). Net IRR (after fees) is what matters to LPs.'},{t:'J-Curve',b:'Years 1&#8211;3: management fees paid, investments written down, no exits &#8594; negative IRR. Years 4&#8211;6: portfolio companies growing, operational improvements. Years 6&#8211;10: exits generate distributions &#8594; IRR rises significantly.'},{t:'IRR vs MOIC',b:'IRR rewards speed: 3&#215; in 3 years (44% IRR) better than 3&#215; in 7 years (17% IRR). MOIC rewards magnitude. IRR can be gamed by quick small exits; use both metrics together for full picture.'}]},
        {title:'Fund Structure & Economics',lv:['l3'],col:'#27AE60',lead:'LP/GP structure. Management fee. Carried interest. Preferred return. Clawback.',
          notes:[{t:'Economics',b:'Management fee: typically 2% on committed capital during investment period &#8594; 1.5% on invested capital during harvest. Carry: 20% of profits above preferred return. Preferred return: 8% (LPs receive this before any carry). Catch-up: GP receives 100% until it has earned 20% of all profits above preferred.'},{t:'Investor Protections',b:'High watermark: GP must recoup prior losses before earning new carry. Clawback: LPs can recover excess carry paid if later losses reduce overall LP return below preferred. Fund life: 10 years typical (5 investment + 5 harvest) with 1&#8211;2 year extensions.'}]},
      ]
    },
    {title:'Private Credit & Infrastructure',lv:['l3'],sum:'Direct lending, mezzanine debt, distressed investing, and infrastructure investment characteristics and valuation.',
      kcs:[
        {title:'Private Credit',lv:['l3'],col:'#C0392B',lead:'Direct lending to middle-market companies. Senior secured. Illiquidity premium over public credit.',
          notes:[{t:'Direct Lending',b:'Floating rate loans: SOFR + 500&#8211;800bps. Senior secured: first priority lien on assets. Unitranche: blends senior and junior in one instrument &#8212; single lender. Higher yield than IG bonds for comparable credit risk (illiquidity premium).'},{t:'Mezzanine & Distressed',b:'Mezzanine: subordinated, includes equity warrants for upside. Distressed: buy debt at discount to par. Active distressed: influence restructuring (become equity). Passive distressed: hold and wait for recovery or par repayment.'}]},
        {title:'Infrastructure',lv:['l3'],col:'#8E44AD',lead:'Long-lived physical assets with regulated/contracted revenues, inflation linkage, and high barriers to entry.',
          notes:[{t:'Greenfield vs Brownfield',b:'Greenfield (build from scratch): construction risk, planning risk, demand uncertainty &#8594; higher return (15%+). Brownfield (acquire operating asset): proven cash flows, lower risk &#8594; lower return (8&#8211;12%). Most institutional investors prefer brownfield; SWFs and development banks fund greenfield.'},{t:'Valuation',b:'DCF: long-term contracted/regulated cash flows. RAB method for utilities: value = regulated asset base &#215; (1 + premium/discount to RAB). EV/EBITDA multiples for deal benchmarking. Key assumptions: regulatory resets, traffic growth, capex cycles, inflation pass-through.'}]},
      ]
    },
  ],
  outcomes:{objective:'Evaluate, structure, and manage PE, private credit, infrastructure, and real asset investments using appropriate valuation methods, performance metrics, and portfolio frameworks.',
    byLevel:{l1:['N/A'],l2:['N/A'],
      l3:['Calculate and interpret IRR, MOIC, DPI, and RVPI for PE fund analysis','Build LBO logic and calculate exit IRR under different scenarios','Evaluate private credit on yield, structure, and credit risk','Apply DCF and RAB methods to infrastructure valuation','Design private markets allocation with pacing model and vintage year diversification']},
    skills:['LBO Modelling','PE Valuation','Private Credit','Infrastructure Analysis','Private Markets Portfolio Construction']},
  resources:[
