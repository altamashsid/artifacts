<style>
*{margin:0;padding:0;box-sizing:border-box;}
:root{
  --red:#C0392B;--red2:#922B21;--rdbg:#FDEDEC;
  --bg:#F5F5F5;--wh:#fff;--bk:#1A1A1A;
  --dk:#2C2C2C;--mid:#555;--mu:#888;--bo:#E0E0E0;
  --l1c:#E67E22;--l2c:#2980B9;--l3c:#27AE60;
  --l1b:#FEF5EC;--l2b:#EBF5FB;--l3b:#EAFAF1;
}
html,body{height:100%;overflow:hidden;font-family:'Source Sans 3',sans-serif;font-size:14px;background:var(--bg);color:var(--bk);}
.app{display:flex;flex-direction:column;height:100vh;}
.topbar{background:var(--red);color:#fff;height:50px;display:flex;align-items:center;justify-content:space-between;padding:0 14px;flex-shrink:0;}
.topbar-title{font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:700;}
.lvls{display:flex;gap:4px;}
.lb{padding:4px 10px;border:1.5px solid rgba(255,255,255,.45);color:rgba(255,255,255,.65);background:none;font-size:.63rem;font-weight:600;letter-spacing:.08em;cursor:pointer;transition:.15s;}
.lb:hover{border-color:#fff;color:#fff;}
.lb.on{background:#fff;color:var(--red);border-color:#fff;}
.bc{background:#222;color:#fff;padding:7px 14px;font-size:.74rem;display:flex;align-items:center;gap:5px;flex-shrink:0;overflow-x:auto;white-space:nowrap;}
.bc::-webkit-scrollbar{display:none;}
.bci{color:rgba(255,255,255,.45);cursor:pointer;transition:.1s;}
.bci:hover,.bci.on{color:#fff;}
.bci.on{font-weight:600;}
.bcsep{color:rgba(255,255,255,.2);}
.tnav{background:#fff;border-bottom:2px solid var(--bo);display:flex;overflow-x:auto;flex-shrink:0;padding:0 6px;}
.tnav::-webkit-scrollbar{display:none;}
.tn{padding:11px 12px;font-size:.68rem;font-weight:600;letter-spacing:.04em;color:var(--mu);cursor:pointer;white-space:nowrap;border-bottom:2.5px solid transparent;margin-bottom:-2px;text-transform:uppercase;transition:.15s;}
.tn:hover{color:var(--dk);}
.tn.on{color:var(--red);border-bottom-color:var(--red);}
.carea{flex:1;overflow-y:auto;background:var(--bg);}
.carea::-webkit-scrollbar{width:3px;}
.carea::-webkit-scrollbar-thumb{background:var(--bo);}
.hero{background:var(--dk);color:#fff;padding:16px 16px 12px;}
.heye{font-size:.6rem;letter-spacing:.14em;text-transform:uppercase;opacity:.5;margin-bottom:4px;}
.htitle{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;margin-bottom:8px;line-height:1.2;}
.htags{display:flex;gap:6px;flex-wrap:wrap;}
.htag{font-size:.6rem;padding:2px 8px;border:1px solid rgba(255,255,255,.2);color:rgba(255,255,255,.6);}
.ctabs{background:#fff;display:flex;border-bottom:1px solid var(--bo);position:sticky;top:0;z-index:50;}
.ct{flex:1;padding:11px 4px;text-align:center;font-size:.67rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--mu);cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-1px;transition:.15s;}
.ct:hover{color:var(--dk);}
.ct.on{color:var(--red);border-bottom-color:var(--red);}
.panel{display:none;padding:14px;}
.panel.on{display:block;}
.lbadge{display:inline-block;font-size:.6rem;font-weight:700;padding:2px 7px;letter-spacing:.07em;margin-right:3px;vertical-align:middle;border-radius:3px;line-height:1.4;}
.lb1{background:var(--l1c);color:#fff;}
.lb2{background:var(--l2c);color:#fff;}
.lb3{background:var(--l3c);color:#fff;}
.lvl-legend{display:flex;gap:10px;align-items:center;padding:8px 14px;background:#fff;border-bottom:1px solid var(--bo);font-size:.67rem;color:var(--mu);}
.lvl-legend span{font-weight:600;margin-right:2px;}
.ll-l1{color:var(--l1c);}
.ll-l2{color:var(--l2c);}
.ll-l3{color:var(--l3c);}
.tree-topic.lv-l1{border-left:4px solid var(--l1c);}
.tree-topic.lv-l2{border-left:4px solid var(--l2c);}
.tree-topic.lv-l3{border-left:4px solid var(--l3c);}
.tree-topic.lv-all{border-left:4px solid var(--mu);}
.tree-topic.dimmed{opacity:.35;pointer-events:none;}
.kc.dimmed{opacity:.3;pointer-events:none;}
.kc-lvl-bar{display:flex;gap:4px;margin-bottom:7px;align-items:center;padding:6px 10px;background:#F8F8F8;border-bottom:1px solid var(--bo);font-size:.63rem;color:var(--mu);}
.ovbox{background:#fff;border-left:3px solid var(--red);padding:12px 14px;margin-bottom:14px;font-size:.81rem;line-height:1.7;color:var(--dk);}
.ovbox strong{display:block;font-size:.88rem;margin-bottom:3px;color:var(--bk);}
.shd{font-family:'Playfair Display',serif;font-size:.92rem;font-weight:700;color:var(--bk);margin:18px 0 8px;display:flex;align-items:center;gap:8px;}
.shd::after{content:'';flex:1;height:1px;background:var(--bo);}
.tree-topic{background:#fff;border:1px solid var(--bo);margin-bottom:5px;border-radius:2px;overflow:hidden;}
.tt-hd{display:flex;align-items:center;gap:8px;padding:11px 14px;cursor:pointer;transition:.12s;}
.tt-hd:hover{background:#FAFAFA;}
.tt-hd.open{background:var(--rdbg);}
.tt-title{font-size:.82rem;font-weight:600;color:var(--bk);flex:1;line-height:1.3;}
.tt-arr{font-size:.62rem;color:var(--mu);transition:transform .2s;flex-shrink:0;}
.tt-hd.open .tt-arr{transform:rotate(180deg);}
.tt-body{display:none;border-top:1px solid var(--bo);}
.tt-body.open{display:block;}
.tt-sum{padding:11px 14px;font-size:.78rem;line-height:1.7;color:var(--mid);background:#FEFEFE;border-bottom:1px solid var(--bo);}
.kc-wrap{padding:8px 12px 10px;}
.kc{border:1px solid var(--bo);border-left:3px solid;margin-bottom:6px;overflow:hidden;border-radius:2px;}
.kc-hd{display:flex;align-items:center;gap:8px;padding:9px 12px;cursor:pointer;transition:.12s;background:#F8F8F8;}
.kc-hd:hover{background:#F2F2F2;}
.kc-hd.open{background:#fff;}
.kc-title{font-size:.78rem;font-weight:600;flex:1;line-height:1.3;color:var(--bk);}
.kc-arr{font-size:.6rem;color:var(--mu);transition:transform .2s;}
.kc-hd.open .kc-arr{transform:rotate(180deg);}
.kc-body{display:none;border-top:1px solid var(--bo);padding:10px 12px;font-size:.76rem;line-height:1.75;color:var(--mid);background:#fff;}
.kc-body.open{display:block;}
.kc-lead{margin-bottom:8px;color:var(--dk);font-size:.79rem;}
.note-block{background:#F4F4F4;border:1px solid #E0E0E0;margin-top:8px;padding:9px 12px;border-radius:2px;}
.nb-title{font-size:.67rem;font-weight:600;color:var(--mu);text-transform:uppercase;letter-spacing:.08em;margin-bottom:5px;}
.nb-text{font-size:.74rem;line-height:1.7;color:var(--mid);}
.lo-obj{background:#fff;border-left:3px solid var(--dk);padding:12px 14px;margin-bottom:12px;font-size:.8rem;line-height:1.7;color:var(--dk);}
.lo-obj strong{display:block;font-size:.87rem;margin-bottom:3px;color:var(--bk);}
.lo-lvl{background:#fff;border:1px solid var(--bo);margin-bottom:8px;overflow:hidden;border-radius:2px;}
.lo-hd{display:flex;align-items:center;gap:8px;padding:10px 14px;cursor:pointer;transition:.12s;}
.lo-hd:hover{filter:brightness(.96);}
.lo-lbl{font-size:.79rem;font-weight:600;color:#fff;letter-spacing:.04em;flex:1;}
.lo-arr{font-size:.62rem;color:rgba(255,255,255,.65);transition:transform .2s;}
.lo-hd.open .lo-arr{transform:rotate(180deg);}
.lo-body{display:none;border-top:1px solid var(--bo);}
.lo-body.open{display:block;}
.lo-item{padding:9px 14px;border-bottom:1px solid #F0F0F0;font-size:.77rem;line-height:1.65;color:var(--dk);display:flex;gap:8px;}
.lo-item:last-child{border-bottom:none;}
.lo-num{font-weight:600;color:var(--red);min-width:18px;font-size:.75rem;}
.lo-deep{padding:10px 14px;background:#F8F8F8;border-top:1px solid var(--bo);}
.lo-dt{font-size:.67rem;font-weight:700;text-transform:uppercase;letter-spacing:.09em;color:var(--mu);margin-bottom:6px;}
.lo-di{font-size:.74rem;line-height:1.65;color:var(--mid);padding:3px 0;border-bottom:1px solid #EBEBEB;display:flex;gap:6px;}
.lo-di:last-child{border-bottom:none;}
.lo-di::before{content:'&#8594;';color:var(--red);flex-shrink:0;}
.skill-row{display:flex;flex-wrap:wrap;gap:5px;padding:11px 14px;background:#fff;border-top:1px solid var(--bo);}
.stag{font-size:.62rem;padding:2px 8px;border:1px solid var(--bo);color:var(--mid);}
.rcat{font-size:.61rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--mu);margin:14px 0 6px;}
.rcard{background:#fff;border:1px solid var(--bo);padding:11px 13px;margin-bottom:6px;display:flex;align-items:flex-start;gap:11px;cursor:pointer;transition:.15s;text-decoration:none;color:inherit;}
.rcard:hover{border-color:var(--red);box-shadow:0 1px 6px rgba(192,57,43,.12);}
.rico{width:36px;height:36px;border-radius:3px;display:flex;align-items:center;justify-content:center;font-size:.95rem;flex-shrink:0;color:#fff;}
.ryt{background:#FF0000;}
.rart{background:#16A085;}
.rprac{background:#8E44AD;}
.rbook{background:#2C3E50;}
.rinfo{flex:1;}
.rtit{font-size:.8rem;font-weight:600;color:var(--bk);margin-bottom:2px;line-height:1.3;}
.rch{font-size:.7rem;color:var(--mu);margin-bottom:4px;}
.rtags{display:flex;gap:4px;flex-wrap:wrap;}
.rtag{font-size:.58rem;padding:1px 6px;border:1px solid var(--bo);color:var(--mu);}
.rtag.free{border-color:#27AE60;color:#27AE60;}
.rtag.paid{border-color:var(--l1c);color:var(--l1c);}
.rtag.l1{border-color:var(--l1c);color:var(--l1c);}
.rtag.l2{border-color:var(--l2c);color:var(--l2c);}
.rtag.l3{border-color:var(--l3c);color:var(--l3c);}
.rext{font-size:.67rem;color:var(--mu);margin-left:auto;flex-shrink:0;align-self:flex-start;padding-top:1px;}
.hstats{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:14px;}
.hstat{background:#fff;border:1px solid var(--bo);padding:12px 8px;text-align:center;}
.hsv{font-family:'Playfair Display',serif;font-size:1.55rem;font-weight:700;line-height:1;margin-bottom:3px;}
.hsl{font-size:.58rem;color:var(--mu);letter-spacing:.08em;text-transform:uppercase;}
.ucard{background:#fff;border:1px solid var(--bo);border-left:4px solid;padding:11px 14px;margin-bottom:5px;cursor:pointer;display:flex;align-items:center;justify-content:space-between;transition:.15s;}
.ucard:hover{box-shadow:0 2px 8px rgba(0,0,0,.07);}
.ucn{font-size:.84rem;font-weight:600;color:var(--bk);}
.ucw{font-size:.69rem;color:var(--mu);margin-top:2px;}
.ucarr{font-size:.85rem;color:var(--mu);}
</style>
</head>
