          h+='</div></div>';
        });
        h+='</div>';
      }
      h+='</div></div>';
    });
  }
  h+='</div>';
  h+='<div class="panel'+(TAB==='outcomes'?' on':'')+'" id="p-outcomes">';
  var oc=d.outcomes;
  h+='<div class="lo-obj"><strong>Learning Objective</strong>'+oc.objective+'</div>';
  var lcfg={l1:{bg:'#E67E22',label:'Level 1'},l2:{bg:'#2980B9',label:'Level 2'},l3:{bg:'#27AE60',label:'Level 3'}};
  ['l1','l2','l3'].forEach(function(lv){
    var items=oc.byLevel[lv];
    if(!items||!items.length)return;
    if(LVL!=='all'&&LVL!==lv)return;
    var lc=lcfg[lv];
    h+='<div class="lo-lvl"><div class="lo-hd" id="lo-'+lv+'-h" style="background:'+lc.bg+'" onclick="togLO(\'lo-'+lv+'\')"><div class="lo-lbl">'+lc.label+' &#8212; What You Must Be Able To Do</div><div class="lo-arr">&#9660;</div></div>';
    h+='<div class="lo-body" id="lo-'+lv+'-b">';
    items.forEach(function(item,i){h+='<div class="lo-item"><div class="lo-num">'+(i+1)+'.</div><div>'+item+'</div></div>';});
    h+='</div></div>';
  });
  if(oc.skills&&oc.skills.length>0){h+='<div class="skill-row">'+oc.skills.map(function(s){return'<span class="stag">'+s+'</span>';}).join('')+'</div>';}
  h+='</div>';
  h+='<div class="panel'+(TAB==='resources'?' on':'')+'" id="p-resources">';
  var tord=['yt','art','prac','book'],tlbl={yt:'&#127909; Video Tutorials',art:'&#128196; Articles & Guides',prac:'&#127919; Practice & Exam Prep',book:'&#128214; Books'},tico={yt:'&#9654;',art:'&#128196;',prac:'&#127919;',book:'&#128214;'},tbg={yt:'ryt',art:'rart',prac:'rprac',book:'rbook'};
  tord.forEach(function(type){
    var shown=(d.resources||[]).filter(function(r){return r.type===type&&(LVL==='all'||r.tags.indexOf(LVL)>=0||r.tags.indexOf('all')>=0);});
    if(!shown.length)return;
    h+='<div class="rcat">'+tlbl[type]+'</div>';
    shown.forEach(function(r){
      h+='<a class="rcard" href="'+(r.url||'#')+'" target="_blank" rel="noopener"><div class="rico '+tbg[type]+'">'+tico[type]+'</div><div class="rinfo"><div class="rtit">'+(r.t||r.title)+'</div><div class="rch">'+(r.ch||'')+'</div><div class="rtags">'+r.tags.map(function(t){return'<span class="rtag '+t+'">'+t.toUpperCase()+'</span>';}).join('')+'</div></div><div class="rext">&#8599; open</div></a>';
    });
  });
  h+='<div style="background:#fff;border:1px solid var(--bo);padding:11px 13px;margin-top:12px;font-size:.72rem;color:var(--mu);line-height:1.65;"><strong style="color:var(--dk);display:block;margin-bottom:3px;">&#128204; Search Tips</strong>Click any card above to open YouTube search results. Mark Meldrum and IFT are widely regarded as the best free resources.</div>';
  h+='</div>';
  area.innerHTML=h;
  area.scrollTop=0;
}
function setLvl(lv){LVL=lv;['all','l1','l2','l3'].forEach(function(l){var el=document.getElementById('lb-'+l);if(el)el.className='lb'+(l===lv?' on':'');});renderContent();}
function go(id){TOP=id;TAB='notes';renderNav();renderBC();renderContent();}
function swTab(tab){TAB=tab;document.querySelectorAll('.ct').forEach(function(el){el.classList.remove('on');});document.querySelectorAll('.panel').forEach(function(el){el.classList.remove('on');});if(event&&event.target)event.target.classList.add('on');var p=document.getElementById('p-'+tab);if(p)p.classList.add('on');}
function togTT(tid){var h=document.getElementById(tid+'-h'),b=document.getElementById(tid+'-b');if(h)h.classList.toggle('open');if(b)b.classList.toggle('open');}
function togKC(kid){var h=document.getElementById(kid+'-h'),b=document.getElementById(kid+'-b');if(h)h.classList.toggle('open');if(b)b.classList.toggle('open');}
function togLO(id){var h=document.getElementById(id+'-h'),b=document.getElementById(id+'-b');if(h)h.classList.toggle('open');if(b)b.classList.toggle('open');}
renderNav();renderBC();renderContent();
</script>
</body>
</html>
