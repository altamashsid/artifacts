    {type:'yt',t:'Estate Planning &#8212; Trusts, Gifting & Tax',ch:'Safeguard Wealth',tags:['free','l3'],url:'https://www.youtube.com/results?search_query=estate+planning+trusts+gifting+tax+basics'},
    {type:'yt',t:'Behavioural Finance &#8212; Why Investors Make Bad Decisions',ch:'The Plain Bagel',tags:['free','l3'],url:'https://www.youtube.com/results?search_query=behavioural+finance+why+investors+bad+decisions'},
