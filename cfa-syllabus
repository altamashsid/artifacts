    {type:'yt',t:'Asset Allocation & Black-Litterman &#8212; L3',ch:'Mark Meldrum',tags:['free','l3'],url:'https://www.youtube.com/results?search_query=CFA+asset+allocation+black+litterman+level+3+mark+meldrum'},
    {type:'yt',t:'Modern Portfolio Theory Explained',ch:'Ben Felix (PWL Capital)',tags:['free','l1','l2'],url:'https://www.youtube.com/results?search_query=modern+portfolio+theory+ben+felix+explained'},
    {type:'yt',t:'Performance Attribution Deep Dive',ch:'AnalystPrep',tags:['free','l3'],url:'https://www.youtube.com/results?search_query=CFA+performance+attribution+brinson+level+3'},
